<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.example.org/medicalOntology#"
     xml:base="http://www.example.org/medicalOntology"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:medicalOntology="http://www.example.org/medicalOntology#">
    <owl:Ontology rdf:about="http://www.example.org/medicalOntology">
        <dc:creator>David Bou Catalán</dc:creator>
        <dc:date>2026-04-17</dc:date>
        <dc:description>Ontology describing medical devices, incidents, risks and corrective actions for regulatory and safety analysis.</dc:description>
        <dc:language>en</dc:language>
        <dc:title>Medical Devices Ontology</dc:title>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <vann:preferredNamespacePrefix>med</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://www.example.org/medicalOntology#</vann:preferredNamespaceUri>
        <rdfs:comment>Ontology for medical devices, incidents and risks</rdfs:comment>
        <rdfs:label>Medical Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/date -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/language -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/language"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/medicalOntology#affectsDevice -->


    <owl:ObjectProperty rdf:about="http://www.example.org/medicalOntology#affectsDevice">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/medicalOntology#Device"/>
        <rdfs:comment>Incident affects a device</rdfs:comment>
        <rdfs:label>affects device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/medicalOntology#derivedFrom -->


    <owl:ObjectProperty rdf:about="http://www.example.org/medicalOntology#derivedFrom">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <rdfs:comment>Corrective action derived from an incident</rdfs:comment>
        <rdfs:label>derived from</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/medicalOntology#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.example.org/medicalOntology#hasManufacturer">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Device"/>
        <rdfs:range rdf:resource="http://www.example.org/medicalOntology#Manufacturer"/>
        <rdfs:comment>Device has a manufacturer</rdfs:comment>
        <rdfs:label>has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/medicalOntology#hasRisk -->


    <owl:ObjectProperty rdf:about="http://www.example.org/medicalOntology#hasRisk">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/medicalOntology#Risk"/>
        <rdfs:comment>Incident has a risk</rdfs:comment>
        <rdfs:label>has risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/medicalOntology#reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/medicalOntology#reportedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/medicalOntology#Manufacturer"/>
        <rdfs:comment>Incident reported by a manufacturer</rdfs:comment>
        <rdfs:label>reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/medicalOntology#actionType -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#actionType">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Type of corrective action</rdfs:comment>
        <rdfs:label>action type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#affectedDeviceType -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#affectedDeviceType">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Type of device affected by the risk</rdfs:comment>
        <rdfs:label>affected device type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#correctiveActionDescription -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#correctiveActionDescription">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Description of the corrective action</rdfs:comment>
        <rdfs:label>corrective action description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#correctiveActionTaken -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#correctiveActionTaken">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>A corrective action has been taken?</rdfs:comment>
        <rdfs:label>corrective action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#countriesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#countriesAffected">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Countries affected to take the corrective action</rdfs:comment>
        <rdfs:label>countries affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#country -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#country">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#countryReported -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#countryReported">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Country where the incident was reported</rdfs:comment>
        <rdfs:label>country reported</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#deviceId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#deviceId">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier of the medical device</rdfs:comment>
        <rdfs:label>device id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#deviceName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#deviceName">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Name of the medical device</rdfs:comment>
        <rdfs:label>device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#deviceType -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#deviceType">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Type of the medical device</rdfs:comment>
        <rdfs:label>device type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#devicesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#devicesAffected">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Number of devices affected</rdfs:comment>
        <rdfs:label>devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#fscaId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#fscaId">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier of the corrective action</rdfs:comment>
        <rdfs:label>fsca id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#incidentDescription -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#incidentDescription">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Description of the incident</rdfs:comment>
        <rdfs:label>incident description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#incidentId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#incidentId">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier of the incident</rdfs:comment>
        <rdfs:label>incident id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#incidentType -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#incidentType">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Type of incident</rdfs:comment>
        <rdfs:label>incident type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#intendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#intendedPurpose">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Intended purpose of the device</rdfs:comment>
        <rdfs:label>intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#manufacturerId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#manufacturerId">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier of the manufacturer</rdfs:comment>
        <rdfs:label>manufacturer id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#manufacturerName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#manufacturerName">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Name of the manufacturer organization</rdfs:comment>
        <rdfs:label>name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#outcome -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#outcome">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Outcome of the incident</rdfs:comment>
        <rdfs:label>outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#patientAge -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#patientAge">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Age of the patient</rdfs:comment>
        <rdfs:label>patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#patientSex -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#patientSex">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Sex of the patient</rdfs:comment>
        <rdfs:label>patient sex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#riskCategory -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#riskCategory">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Category of the risk</rdfs:comment>
        <rdfs:label>risk category</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#riskClass -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#riskClass">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Risk class of the device</rdfs:comment>
        <rdfs:label>risk class</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#riskDescription -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#riskDescription">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Description of the risk</rdfs:comment>
        <rdfs:label>risk description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#riskId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#riskId">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier of the risk</rdfs:comment>
        <rdfs:label>risk id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#riskName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#riskName">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Name of the risk</rdfs:comment>
        <rdfs:label>risk name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#riskType -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#riskType">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Type of risk</rdfs:comment>
        <rdfs:label>risk type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#scope -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#scope">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Scope of the corrective action</rdfs:comment>
        <rdfs:label>scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/medicalOntology#status -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/medicalOntology#status">
        <rdfs:domain rdf:resource="http://www.example.org/medicalOntology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Current status of the corrective action</rdfs:comment>
        <rdfs:label>status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/medicalOntology#ActiveDevice -->


    <owl:Class rdf:about="http://www.example.org/medicalOntology#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/medicalOntology#Device"/>
        <rdfs:comment>Active medical device</rdfs:comment>
        <rdfs:label>Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/medicalOntology#ActiveImplant -->


    <owl:Class rdf:about="http://www.example.org/medicalOntology#ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://www.example.org/medicalOntology#Device"/>
        <rdfs:comment>Active implant device</rdfs:comment>
        <rdfs:label>Active Implant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/medicalOntology#ContaminationRisk -->


    <owl:Class rdf:about="http://www.example.org/medicalOntology#ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/medicalOntology#Risk"/>
        <rdfs:comment>Risk related to contamination on the device</rdfs:comment>
        <rdfs:label>Contamination Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/medicalOntology#CorrectiveAction -->


    <owl:Class rdf:about="http://www.example.org/medicalOntology#CorrectiveAction">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/medicalOntology#derivedFrom"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <owl:hasKey rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.example.org/medicalOntology#fscaId"/>
        </owl:hasKey>
        <rdfs:comment>Action taken to correct an incident</rdfs:comment>
        <rdfs:label>Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/medicalOntology#CybersecurityRisk -->


    <owl:Class rdf:about="http://www.example.org/medicalOntology#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/medicalOntology#Risk"/>
        <rdfs:comment>Risk related to cybersecurity issues</rdfs:comment>
        <rdfs:label>Cybersecurity Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/medicalOntology#Device -->


    <owl:Class rdf:about="http://www.example.org/medicalOntology#Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/medicalOntology#hasManufacturer"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.example.org/medicalOntology#Incident"/>
        <owl:hasKey rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.example.org/medicalOntology#deviceId"/>
        </owl:hasKey>
        <rdfs:comment>Medical device</rdfs:comment>
        <rdfs:label>Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/medicalOntology#DiagnosticRisk -->


    <owl:Class rdf:about="http://www.example.org/medicalOntology#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/medicalOntology#Risk"/>
        <rdfs:comment>Risk of incorrect diagnostic</rdfs:comment>
        <rdfs:label>Diagnostic Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/medicalOntology#IVDDevice -->


    <owl:Class rdf:about="http://www.example.org/medicalOntology#IVDDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/medicalOntology#Device"/>
        <rdfs:comment>In vitro diagnostic medical device</rdfs:comment>
        <rdfs:label>IVD Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/medicalOntology#ImplantableActiveDevice -->


    <owl:Class rdf:about="http://www.example.org/medicalOntology#ImplantableActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/medicalOntology#Device"/>
        <rdfs:comment>Implantable and active medical device</rdfs:comment>
        <rdfs:label>Implantable Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/medicalOntology#ImplantableDevice -->


    <owl:Class rdf:about="http://www.example.org/medicalOntology#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/medicalOntology#Device"/>
        <rdfs:comment>Implantable medical device</rdfs:comment>
        <rdfs:label>Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/medicalOntology#Incident -->


    <owl:Class rdf:about="http://www.example.org/medicalOntology#Incident">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/medicalOntology#affectsDevice"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/medicalOntology#hasRisk"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/medicalOntology#reportedBy"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.example.org/medicalOntology#Manufacturer"/>
        <owl:disjointWith rdf:resource="http://www.example.org/medicalOntology#Risk"/>
        <owl:hasKey rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.example.org/medicalOntology#incidentId"/>
        </owl:hasKey>
        <rdfs:comment>Device malfunction</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/medicalOntology#InfectionRisk -->


    <owl:Class rdf:about="http://www.example.org/medicalOntology#InfectionRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/medicalOntology#Risk"/>
        <rdfs:comment>Risk of infection by a medical device</rdfs:comment>
