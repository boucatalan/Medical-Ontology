    <!-- http://www.example.org/medicalOntology#FSCA-001 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/medicalOntology#FSCA-001">
        <rdf:type rdf:resource="http://www.example.org/medicalOntology#CorrectiveAction"/>
        <derivedFrom rdf:resource="http://www.example.org/medicalOntology#INC-001"/>
        <actionType>SafetyAlert</actionType>
        <correctiveActionDescription>Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0.</correctiveActionDescription>
        <countriesAffected>EU-wide</countriesAffected>
        <devicesAffected>850</devicesAffected>
        <fscaId>FSCA-001</fscaId>
        <scope>All HeartMate 3 LVAD units implanted since 2020</scope>
        <status>Open</status>
        <rdfs:label>CorrectiveAction 001 - Safety alert for HeartMate thrombosis risk</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/medicalOntology#FSCA-002 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/medicalOntology#FSCA-002">
        <rdf:type rdf:resource="http://www.example.org/medicalOntology#CorrectiveAction"/>
        <derivedFrom rdf:resource="http://www.example.org/medicalOntology#INC-002"/>
        <actionType>Recall</actionType>
        <correctiveActionDescription>Voluntary recall of affected Micra AV lots due to premature battery depletion. Replacement units provided. 97% of affected devices successfully replaced.</correctiveActionDescription>
        <countriesAffected>EU-wide + UK</countriesAffected>
        <devicesAffected>1240</devicesAffected>
        <fscaId>FSCA-002</fscaId>
        <scope>Micra AV lots manufactured between 2022-09 and 2023-03</scope>
        <status>Closed</status>
        <rdfs:label>CorrectiveAction 002 - Recall of Micra AV devices</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/medicalOntology#FSCA-003 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/medicalOntology#FSCA-003">
        <rdf:type rdf:resource="http://www.example.org/medicalOntology#CorrectiveAction"/>
        <derivedFrom rdf:resource="http://www.example.org/medicalOntology#INC-003"/>
        <actionType>InSituCorrection</actionType>
        <correctiveActionDescription>Enhanced deployment training and updated IFU for Portico valve implantation technique. New implantation checklist mandatory for all TAVI centres.</correctiveActionDescription>
        <countriesAffected>EU-wide</countriesAffected>
        <devicesAffected>320</devicesAffected>
        <fscaId>FSCA-003</fscaId>
        <scope>Portico THV sizes 23mm and 25mm from lots before 2023-11</scope>
        <status>Closed</status>
        <rdfs:label>CorrectiveAction 003 - Portico valve deployment improvement</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/medicalOntology#FSCA-004 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/medicalOntology#FSCA-004">
        <rdf:type rdf:resource="http://www.example.org/medicalOntology#CorrectiveAction"/>
        <derivedFrom rdf:resource="http://www.example.org/medicalOntology#INC-005"/>
        <actionType>SafetyAlert</actionType>
        <correctiveActionDescription>Safety communication to implanting cardiologists regarding optimal fixation technique for ACUITY X4 lead. Enhanced fluoroscopy verification protocol at implantation.</correctiveActionDescription>
        <countriesAffected>EU-wide</countriesAffected>
        <devicesAffected>2100</devicesAffected>
        <fscaId>FSCA-004</fscaId>
        <scope>All ACUITY X4 quadripolar LV leads</scope>
        <status>Open</status>
        <rdfs:label>CorrectiveAction 004 - Safety communication for ACUITY X4 lead</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/medicalOntology#INC-001 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/medicalOntology#INC-001">
        <rdf:type rdf:resource="http://www.example.org/medicalOntology#SeriousIncident"/>
        <affectsDevice rdf:resource="http://www.example.org/medicalOntology#DEV-001"/>
        <hasRisk rdf:resource="http://www.example.org/medicalOntology#RSK-003"/>
        <reportedBy rdf:resource="http://www.example.org/medicalOntology#MAN-001"/>
        <correctiveActionTaken rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</correctiveActionTaken>
        <countryReported>Germany</countryReported>
        <incidentDescription>Patient implanted with HeartMate 3 LVAD developed ischemic stroke 6 months post-implant. Device thrombus confirmed by echocardiography.</incidentDescription>
        <incidentId>INC-001</incidentId>
        <incidentType>SeriousIncident</incidentType>
        <outcome>Serious patient injury - embolic stroke</outcome>
        <patientAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">58</patientAge>
        <patientSex>Male</patientSex>
        <rdfs:label>Incident 001 - Serious patient injury - embolic stroke</rdfs:label>
    </owl:NamedIndividual>
    


